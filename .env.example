# Database
DATABASE_URL=postgresql+asyncpg://venderweb:venderweb@localhost:5432/venderweb
DATABASE_URL_SYNC=postgresql://venderweb:venderweb@localhost:5432/venderweb

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Places API (Capa 3 - validacion selectiva)
GOOGLE_PLACES_API_KEY=

# Perplexity API (Capa 2 - enriquecimiento)
PERPLEXITY_API_KEY=

# Scraping (Capa 1)
PROXY_URL=
SCRAPE_DELAY_SECONDS=10
SCRAPE_MAX_CONCURRENT=3

# Auth
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# App
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
